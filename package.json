{
  "name": "nightcrawler",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-license-header": "^0.9.0",
    "espree": "^11.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6"
  },
  "packageManager": "bun@1.3.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:site": "bun run --filter @nightcrawler/site dev",
    "dev:sanity": "bun run --filter @nightcrawler/sanity dev",
    "dev:internal": "bun run --filter @nightcrawler/internal dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "storybook": "bun run --filter @nightcrawler/site storybook",
    "build-storybook": "bun run --filter @nightcrawler/site build-storybook",
    "db:local:up": "bun run --filter @nightcrawler/db db:local:up",
    "db:local:down": "bun run --filter @nightcrawler/db db:local:down",
    "db:local:wipe": "bun run --filter @nightcrawler/db db:local:wipe",
    "db:local:migrate": "bun run --filter @nightcrawler/db db:local:migrate",
    "db:local:seed": "bun run --filter @nightcrawler/db db:local:seed",
    "db:local:init": "bun run --filter @nightcrawler/db db:local:init",
    "db:local:reset": "bun run --filter @nightcrawler/db db:local:reset",
    "db:create-admin-farm-user": "bun run --filter @nightcrawler/db db:create-admin-farm-user",
    "db:seed-knowledge": "bun run --filter @nightcrawler/db db:seed-knowledge",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "bun run format:check && bun run type-check && bun run lint && bun run test && bun run build",
    "prepare": "husky",
    "clean": "rm -rf node_modules apps/site/node_modules apps/sanity/node_modules apps/internal/node_modules packages/db/node_modules bun.lockb apps/site/bun.lockb apps/sanity/bun.lockb apps/internal/bun.lockb packages/db/bun.lockb apps/site/.next apps/internal/.next apps/site/storybook-static apps/site/coverage apps/sanity/.sanity apps/sanity/.dist"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/eslint-plugin": "^1.6.15",
    "ajv": "^8.18.0",
    "basic-ftp": "^5.3.0",
    "esbuild": "^0.28.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-no-secrets": "^2.3.3",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "minimatch": "^10.2.5",
    "rollup": "^4.60.1",
    "storybook": "^10.3.5",
    "undici": "^7.24.7"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "lodash": "^4.17.24",
    "lodash-es": "^4.17.24",
    "js-yaml": "^4.1.1",
    "esbuild": "^0.25.0",
    "minimatch": "^10.2.3",
    "markdown-it": "^14.1.1",
    "picomatch": "^4.0.4",
    "rollup": "^4.59.0",
    "basic-ftp": "^5.2.0",
    "tar": "^7.5.11",
    "dompurify": "3.3.2",
    "undici": "^7.24.0",
    "vite": "^7.3.2",
    "protobufjs": "^7.5.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md,yml,yaml,html}": [
      "prettier --write"
    ]
  }
}
